# TokenTrim configuration (all optional — sensible defaults apply)

# Master switch
TOKENTRIM_ENABLED=1

# Compression aggressiveness: light | balanced | aggressive
TOKENTRIM_LEVEL=balanced

# Only compress payloads larger than this many tokens (smaller content is passed through)
TOKENTRIM_MIN_TOKENS=300

# Reversible store (CCR) — where originals are cached for on-demand retrieval
TOKENTRIM_STORE_DIR=.tokentrim/store
# Time-to-live for cached originals, in seconds (default 24h)
TOKENTRIM_STORE_TTL=86400

# Token counting backend: heuristic | tiktoken
TOKENTRIM_TOKENIZER=heuristic
# Model/tier name used for cost estimates and (optionally) tiktoken counts.
# Unknown names fall back to a conservative default price.
TOKENTRIM_MODEL=default
# Override input price (USD per 1M tokens) for cost reporting on unknown models
# TOKENTRIM_INPUT_PRICE_PER_MTOK=2.50

# Redact secrets (API keys, tokens, passwords) before compression
TOKENTRIM_REDACT_SECRETS=1

# --- Quality & dedup (output quality + token reduction) ---
# Minimum fidelity (important-token recall) to accept lossy PROSE compression.
# If a text/table block drops below this, the original is sent instead. 0 disables.
TOKENTRIM_QUALITY_THRESHOLD=0.35
# Collapse exact + near-duplicate blocks and repeated messages
TOKENTRIM_DEDUP=1
# Strip markdown emphasis / collapse whitespace on prose (TokenOpt)
TOKENTRIM_NORMALIZE_WHITESPACE=1

# --- Proxy mode (drop-in chat-completions endpoint) ---
# Upstream provider base URL the proxy forwards to (REQUIRED for proxy mode; no default).
# TOKENTRIM_UPSTREAM_BASE_URL=https://your-provider.example/v1
# Bind address for `tokentrim proxy`
TOKENTRIM_PROXY_HOST=127.0.0.1
TOKENTRIM_PROXY_PORT=8787
# Exact-match response cache: skip identical LLM calls entirely (cost reduction).
# Safe for deterministic requests (temperature 0). Off by default.
TOKENTRIM_CACHE_RESPONSES=0
TOKENTRIM_CACHE_TTL=3600
